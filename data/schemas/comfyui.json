[
  {
    "type": "function",
    "function": {
      "name": "comfyui.generate_image",
      "description": "Generate an image using ComfyUI with FLUX or other loaded checkpoint",
      "parameters": {
        "type": "object",
        "properties": {
          "prompt": {"type": "string", "description": "Text prompt describing the image to generate"},
          "negative_prompt": {"type": "string", "description": "Negative prompt for undesired elements"},
          "model": {"type": "string", "description": "Checkpoint model name (default: 'flux1-dev')"},
          "lora": {"type": "string", "description": "LoRA name to apply (e.g., 'celebrity_name', 'style_name')"},
          "lora_strength": {"type": "number", "description": "LoRA strength (default: 1.0, range: 0.0-2.0)"},
          "steps": {"type": "integer", "description": "Number of sampling steps (default: 20)"},
          "cfg": {"type": "number", "description": "CFG scale / guidance (default: 3.5 for FLUX)"},
          "width": {"type": "integer", "description": "Image width in pixels (default: 1024)"},
          "height": {"type": "integer", "description": "Image height in pixels (default: 1024)"},
          "seed": {"type": "integer", "description": "Random seed (-1 for random)"},
          "sampler": {"type": "string", "enum": ["euler", "euler_ancestral", "dpmpp_2m", "dpmpp_sde", "ddim", "uni_pc"], "description": "Sampler algorithm"},
          "scheduler": {"type": "string", "enum": ["normal", "karras", "exponential", "sgm_uniform", "simple", "beta"], "description": "Noise scheduler"},
          "batch_size": {"type": "integer", "description": "Number of images to generate (default: 1)"}
        },
        "required": ["prompt"]
      }
    }
  },
